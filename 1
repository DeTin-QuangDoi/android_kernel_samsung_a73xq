name: Samsung A73 Vanilla Build

on:
  workflow_dispatch: 
  push:
    branches: [ main, master ]

jobs:
  build:
    runs-on: ubuntu-22.04

    steps:
      - name: Checkout Kernel Source
        uses: actions/checkout@v4

      - name: Free Disk Space
        uses: endersonmenezes/free-disk-space@v3
        with:
          remove_android: true
          remove_tool_cache: true

      - name: Install Build Dependencies
        run: |
          sudo apt update
          sudo apt install -y bc build-essential flex bison libssl-dev libelf-dev \
          ccache libncurses-dev python3 git-lfs aria2
          
          wget -q http://security.ubuntu.com/ubuntu/pool/universe/n/ncurses/libtinfo5_6.3-2ubuntu0.1_amd64.deb
          sudo dpkg -i libtinfo5_6.3-2ubuntu0.1_amd64.deb || sudo apt-get install -f -y

      - name: Fetch Toolchains
        run: |
          rm -rf toolchain
          mkdir -p toolchain/gcc/linux-x86/aarch64
          mkdir -p toolchain/llvm-arm-toolchain-ship/10.0
          
          git clone --depth=1 https://github.com/LineageOS/android_prebuilts_gcc_linux-x86_aarch64_aarch64-linux-android-4.9 -b lineage-18.1 \
          toolchain/gcc/linux-x86/aarch64/aarch64-linux-android-4.9
          
          AOSPTC_URL="https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86/+archive/refs/heads/main/clang-r530567.tar.gz"
          aria2c -x 16 -s 16 -o "clang.tar.gz" "$AOSPTC_URL"
          tar -xf clang.tar.gz -C toolchain/llvm-arm-toolchain-ship/10.0
          rm clang.tar.gz

      - name: Build Kernel
        run: |
          chmod +x build_kernel.sh
          ./build_kernel.sh
        env:
          KBUILD_BUILD_USER: "Lixin"
          KBUILD_BUILD_HOST: "GitHub-Actions"

      - name: Pack Image with DTB
        run: |

          DTB_PATH="out/arch/arm64/boot/dts/samsung/yupik.dtb"
          IMAGE_PATH="out/arch/arm64/boot/Image"
          
          if [ -f "$DTB_PATH" ]; then
            echo "--- Đang nối DTB vào Image ---"
            cat "$IMAGE_PATH" "$DTB_PATH" > out/arch/arm64/boot/Image-dtb
            echo "✅ Đã tạo thành công Image-dtb"
          else
            echo "❌ Không tìm thấy file DTB tại $DTB_PATH. Kiểm tra lại tên file dts."

            ls out/arch/arm64/boot/dts/samsung/
          fi

      - name: Upload Build Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: Vanilla-Kernel-A73-Packed
          path: |
            out/arch/arm64/boot/Image
            out/arch/arm64/boot/Image-dtb
            out/arch/arm64/boot/dts/samsung/*.dtb
            out/arch/arm64/boot/dtbo.img

